rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin access rules: allow if user email is admin (in real app we check custom claims, but for now we might allow read)
    // Here we can allow read for all or authenticated users based on the requirements.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
